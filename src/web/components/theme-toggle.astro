---
import Icon from './icon.astro';
---

<button
  id="theme-toggle"
  aria-label="Theme toggle"
  type="button"
  data-tooltip="Toggle theme"
  class="fixed bottom-3 left-3 z-10 inline-flex h-10 w-16 items-center rounded-full bg-white p-1 text-gray-500 shadow-xl ring-1 ring-black/5 transition focus:ring-primary-500 dark:bg-gray-700 dark:text-gray-100"
>
  <span class="grid h-8 w-8 place-items-center rounded-full bg-gray-100 transition-transform dark:translate-x-6 dark:bg-gray-600">
    <Icon class="block dark:hidden" name="ri:moon-fill" size={18} />
    <Icon class="hidden dark:block" name="ri:sun-line" size={18} />
  </span>
</button>

<script is:inline>
  const themeToggle = document.getElementById('theme-toggle');

  const applyTheme = (theme) => {
    document.documentElement.classList.toggle('dark', theme === 'dark');
    themeToggle?.setAttribute('aria-pressed', String(theme === 'dark'));
  };

  const toggleTheme = () => {
    const theme = localStorage.getItem('theme') ?? 'light';
    const newTheme = theme === 'light' ? 'dark' : 'light';
    const themeMeta = document.querySelector('meta[name="theme-color"]');

    if (themeMeta) {
      themeMeta.setAttribute('content', newTheme === 'dark' ? '#111827' : '#f9fafb');
    }

    applyTheme(newTheme);
    localStorage.setItem('theme', newTheme);
  };

  applyTheme(localStorage.getItem('theme') ?? (document.documentElement.classList.contains('dark') ? 'dark' : 'light'));
  themeToggle?.addEventListener('click', toggleTheme);
</script>
