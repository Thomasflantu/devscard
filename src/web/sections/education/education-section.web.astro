---
import type { EducationSection } from '@/types/sections/education-section.types';
import type { I18nConfig } from '@/types/config/i18n-config.types';
import Divider from '@/web/components/divider.astro';
import SectionCard from '@/web/components/section-card.astro';
import Diploma from './diploma.astro';

export interface Props extends EducationSection {
  i18n: I18nConfig;
}

const { config, diplomas, i18n } = Astro.props;
---

<SectionCard {...config}>
  {diplomas.flatMap((diploma) => [<Diploma {...diploma} i18n={i18n} />, <Divider />])}
</SectionCard>
