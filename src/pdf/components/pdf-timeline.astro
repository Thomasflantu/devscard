---
import type { SiteLocale } from '@/data/locales';

interface Props {
  locale: SiteLocale;
}

const { locale } = Astro.props;

const timeline =
  locale === 'nl'
    ? [
        { date: '2020', title: 'Avans', text: 'Technische Informatica' },
        { date: '2021', title: 'BijGepast', text: 'Mede-eigenaar' },
        { date: '2025', title: 'Optimation', text: 'Afstudeerstage' },
        { date: 'Nu', title: 'Software Engineer', text: '.NET, C# en automatisering' },
      ]
    : [
        { date: '2020', title: 'Avans', text: 'Technical Informatics' },
        { date: '2021', title: 'BijGepast', text: 'Co-owner' },
        { date: '2025', title: 'Optimation', text: 'Graduation internship' },
        { date: 'Now', title: 'Software Engineer', text: '.NET, C#, and automation' },
      ];
---

<div class="relative grid grid-cols-4 gap-3">
  <div class="absolute left-8 right-8 top-4 h-px bg-gray-200" />
  {
    timeline.map((item) => (
      <div class="relative text-center">
        <div class="mx-auto grid h-8 w-8 place-items-center rounded-full bg-primary-600 text-[11px] font-extrabold text-white ring-4 ring-white">
          {item.date}
        </div>
        <div class="mt-2 rounded-lg bg-gray-50 px-2 py-2">
          <div class="text-[13px] font-extrabold text-gray-900">{item.title}</div>
          <div class="mt-0.5 text-[11px] leading-snug text-gray-600">{item.text}</div>
        </div>
      </div>
    ))
  }
</div>
