---
import type { Photo } from '@/types/shared';
import { Image } from 'astro:assets';

export interface Props {
  src: Photo;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
}

const { src, alt, class: className = '', ...props } = Astro.props;

const isRemoteImage = typeof src === 'string';
---

{
  isRemoteImage ? (
    <img src={src} alt={alt} class={`object-cover ${className}`} {...props} />
  ) : (
    <Image format="webp" fit="cover" loading="eager" src={src} alt={alt} class={`object-cover ${className}`} {...props} />
  )
}
