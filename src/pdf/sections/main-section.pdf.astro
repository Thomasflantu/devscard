---
import type { MainSection } from '@/types/sections/main-section.types';
import Photo from '@/components/photo.astro';
import Description from '@/pdf/components/description.astro';
import LabelledValue from '@/pdf/components/labelled-value.astro';

export interface Props extends MainSection {}

const { image, fullName, role, details, pdfDetails, description } = Astro.props;
---

<div class="rounded-2xl bg-white p-6 shadow-md">
  <div class="flex gap-6">
    <Photo
      src={image}
      alt={fullName}
      class="ring-black/10 h-36 max-h-[144px] w-36 max-w-[144px] rounded-2xl shadow-lg ring-1"
    />
    <div class="flex flex-1 flex-col justify-center">
      <div class="text-4xl font-extrabold leading-tight text-gray-900">{fullName}</div>
      <div class="mt-1 text-xl font-medium text-gray-700">{role}</div>
      <div class="mt-4 grid grid-cols-[auto_auto] gap-x-4 gap-y-1 text-sm">
        {
          (pdfDetails ?? details).map((detail) => (
            <LabelledValue {...detail} class={detail.fullRow ? 'col-span-2' : undefined} />
          ))
        }
      </div>
    </div>
  </div>
  <div class="mt-5">
    <Description content={description} class="text-gray-950" />
  </div>
</div>
