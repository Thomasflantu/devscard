---
import type { Photo } from '@/types/shared';
import { Image } from 'astro:assets';

export interface Props {
  src: Photo;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
}

const { src, alt, class: className = '', ...props } = Astro.props;

const isRemoteImage = typeof src === 'string';
const loading = import.meta.env.PUBLIC_APP_ENV === 'snapshot' ? 'eager' : 'lazy';
---

{
  isRemoteImage ? (
    <img src={src} alt={alt} class={`object-cover ${className}`} {...props} />
  ) : (
    <Image
      src={src}
      alt={alt}
      loading={loading}
      format="webp"
      class={`object-cover ${className}`}
      {...props}
    />
  )
}
